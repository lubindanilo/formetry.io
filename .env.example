PORT=3000
# MongoDB local ou MongoDB Atlas (niveau gratuit disponible) : mongodb+srv://user:pass@cluster.mongodb.net/formcoach
MONGO_URL=mongodb://mongo:27017/formcoach
# Secret pour signer les JWT (obligatoire pour l'authentification)
JWT_SECRET=your-super-secret-key-change-in-production
# When API runs in Docker: use detection/scoring hostnames. When API runs on host: use localhost.
DETECTION_URL=http://detection:8000
SCORING_URL=http://scoring:8000

AWS_REGION=eu-west-3
S3_BUCKET=YOUR_BUCKET_NAME
AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_SECRET
